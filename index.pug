doctype html
html.h-100(data-bs-theme="dark")
  head
    title Cloak Data Editor
    link(rel="stylesheet" href="styles/styles.scss")
    script(src="scripts/form.js")
    script(src="scripts/page.ts")
    script(src="scripts/cloak.ts")
    script(src="scripts/index.ts")
    script(src="node_modules/bootstrap/dist/js/bootstrap.bundle.js")
  body.h-100
    //- GRID
    .row.g-0.h-100
      //- COL
      #sidebar.col.h-100.border-end.d-flex.flex-column.overflow-y-auto
        #infoUpdateAvail.text.text-center.bg-secondary.text-light.m-1.mb-0(hidden) Update available
        #errorOpenFile.text.text-center.bg-danger.text-light.m-1.mb-0(hidden) Failed to open file (see console)
        #errorSaveFile.text.text-center.bg-danger.text-light.m-1.mb-0(hidden) Failed to save file (see console)
        .p-1.sticky-top.bg-dark.d-flex
          button#openFileBtn.btn.btn-primary.flex-shrink-0 Open File
          button#saveFileBtn.btn.btn-primary.flex-shrink-0(hidden) Save File
          #fileNameLbl.text.flex-grow-1.overflow-ellipsis No file open.
        #list.px-1.flex-grow-1
        .p-1.sticky-bottom.bg-dark.d-flex
          .dropdown.flex-shrink-0
            button#createItemBtn.btn.btn-secondary.dropdown-toggle(data-bs-toggle="dropdown" hidden) Create Item
            ul#createItemMenu.dropdown-menu
          #versionLbl.text.text-end.flex-grow-1
      //- COL
      #main.col.h-100.overflow-y-auto.bg-dark-subtle
        include partials/mixins
        include partials/cloak